# Copy to .env and fill in what you have. Everything here can also be set
# live in the Gradio Settings panel without restarting the app; env vars
# just supply the startup defaults. See README.md for details.

# --- API keys ---
# No Google API key here: chat, structured extraction/evaluation, and Google
# Search grounding always authenticate via Application Default Credentials
# (gcloud auth application-default login, or GOOGLE_APPLICATION_CREDENTIALS)
# against the Enterprise Agent Platform (formerly Vertex AI) endpoint. You'll
# also need GOOGLE_CLOUD_PROJECT (and optionally GOOGLE_CLOUD_LOCATION) set --
# these are read directly by the google-genai SDK, not PONDERCANVAS_*. Image
# generation with the Gemini provider is separate and still needs its own key
# regardless -- see PONDERCANVAS_GEMINI_IMAGE_API_KEY below.

# Only needed if you select the corresponding chat/image provider below.
PONDERCANVAS_OPENAI_API_KEY=
PONDERCANVAS_ANTHROPIC_API_KEY=
PONDERCANVAS_STABILITY_API_KEY=

# Optional: enables real reference photos (downloaded from Unsplash, with
# attribution shown in the UI) alongside Google Search text grounding.
# Get an Access Key at unsplash.com/developers. Text grounding still works
# without this.
PONDERCANVAS_UNSPLASH_API_KEY=

# --- Providers & models ---
# chat_provider: gemini | openai | anthropic
PONDERCANVAS_CHAT_PROVIDER=gemini
PONDERCANVAS_CHAT_MODEL_ID=gemini-3.5-flash

# image_provider: gemini | openai | stability (openai/stability not yet implemented)
PONDERCANVAS_IMAGE_PROVIDER=gemini
PONDERCANVAS_IMAGE_MODEL_ID=gemini-3.1-flash-image

# Optional, Gemini image provider only: routes image generation through the
# Gemini Enterprise Agent Platform (formerly Vertex AI) endpoint instead of
# the standard Gemini Developer API. CURRENTLY BROKEN for image generation --
# the Interactions API this app uses isn't deployed on that endpoint yet, so
# enabling this raises a clear RuntimeError instead of generating (see
# README). Leave false unless/until that changes.
PONDERCANVAS_GEMINI_IMAGE_ENTERPRISE=false
# Required for the Gemini image provider (no fallback to another key).
PONDERCANVAS_GEMINI_IMAGE_API_KEY=

# Optional, Gemini image provider only: lets the image model use its own
# Google Search tool (image_search) for extra visual grounding at generation
# time, alongside Unsplash reference photos. On by default; no separate key
# needed (uses the Gemini image API key above).
PONDERCANVAS_GEMINI_IMAGE_SEARCH_ENABLED=true

# Always Gemini regardless of the providers above (see README).
PONDERCANVAS_STRUCTURED_MODEL_ID=gemini-3.5-flash

# --- Pipeline behavior ---
# Refinement loop mode: "fast" (plain for-loop, no per-iteration LLM calls for
# orchestration), "thinking" (ADK Workflow graph, an extra chat-model call per
# step, self-authored prompts + optional web/reference search), or "instant"
# (single generate call, no loop, no evaluation).
PONDERCANVAS_REFINEMENT_MODE=fast
PONDERCANVAS_MAX_ITERATIONS=3
PONDERCANVAS_EVAL_PASS_THRESHOLD=4.0
PONDERCANVAS_ASPECT_RATIO=1:1
PONDERCANVAS_MAX_REFERENCE_DOWNLOADS=3
PONDERCANVAS_MAX_DOWNLOAD_BYTES=5000000
PONDERCANVAS_DOWNLOAD_TIMEOUT_S=5.0
PONDERCANVAS_OUTPUT_DIR=./.pondercanvas_runs

# Optional: blend a SigLIP image/prompt similarity score into evaluation.
# Requires `uv sync --extra siglip` (torch + transformers); if that model
# can't load, this is silently ignored for the run (see README).
PONDERCANVAS_SIGLIP_ENABLED=false
PONDERCANVAS_SIGLIP_WEIGHT=0.3

# --- Testing ---
# Set to 1 to allow live tests (requires PONDERCANVAS_GEMINI_IMAGE_API_KEY
# and working Application Default Credentials in the environment):
#   PONDERCANVAS_RUN_LIVE_TESTS=1 uv run pytest -m live
PONDERCANVAS_RUN_LIVE_TESTS=0

# --- Tracing (W&B Weave) ---
# Unprefixed (not PONDERCANVAS_*): read directly by the wandb/weave SDKs, not
# through AppSettings. Optional -- if WANDB_API_KEY is unset, tracing is
# skipped and the app runs exactly as before. Get a key at wandb.ai/authorize.
WANDB_API_KEY=
WANDB_PROJECT=nhaddad2112-duckasaurus/PonderCanvas
